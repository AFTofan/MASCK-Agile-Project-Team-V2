@page
@model WebApplication1.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<link rel="stylesheet" href="~/css/auth-global.css" />

<div class="auth-page">
    <div class="container">
        <div class="auth-card">
            <div class="auth-header">
                <h2>Create Account</h2>
                <p>Join MASCK and start earning points through games and activities.</p>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="auth-panel">
                        <h3>Register</h3>

                        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="auth-form-group">
                                <label asp-for="Input.Email" class="auth-label"></label>
                                <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="auth-form-group">
                                <label asp-for="Input.Password" class="auth-label"></label>
                                <input asp-for="Input.Password" class="form-control auth-input" autocomplete="new-password" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="auth-form-group">
                                <label asp-for="Input.ConfirmPassword" class="auth-label"></label>
                                <input asp-for="Input.ConfirmPassword" class="form-control auth-input" autocomplete="new-password" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button id="registerSubmit" type="submit" class="btn auth-primary-btn w-100">
                                Register
                            </button>

                            <div class="auth-links">
                                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Already have an account? Log in</a>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="auth-panel auth-panel-secondary">
                        <h3>Why join?</h3>
                        <div class="auth-empty-state">
                            <div class="auth-empty-icon">🎮</div>
                            <p>Create an account to track your points, rewards, and game progress.</p>
                            <span>Quizzes, puzzles, QR rewards and more.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}