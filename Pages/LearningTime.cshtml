@page
@model WebApplication1.Pages.LearningTimeModel
@{
    ViewData["Title"] = "Learning Time";
}

<div class="masck-hero mb-4">
    <h1 class="fw-bold mb-1">Learning Time</h1>
    <div class="text-muted">Complete lessons to earn points (each lesson can be completed once).</div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<div class="row g-3">
    @foreach (var lesson in Model.Lessons)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card masck-card p-4 h-100">
                <h5 class="fw-bold">@lesson.Title</h5>
                <p class="text-muted mb-3">@lesson.Description</p>

                <div class="d-flex justify-content-between align-items-center mt-auto">
                    <span class="badge bg-light text-dark">+@lesson.Points pts</span>

                    @if (lesson.IsCompleted)
                    {
                        <span class="text-success fw-bold">Completed ✅</span>
                    }
                    else
                    {
                        <form method="post">
                            <input type="hidden" name="lessonKey" value="@lesson.Key" />
                            <button class="btn btn-masck" type="submit">Complete</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>