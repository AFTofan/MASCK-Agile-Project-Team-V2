@using Microsoft.AspNetCore.Identity
@using WebApplication1.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    // Only query the DB when the user is signed in
    var points = 0;

    if (SignInManager.IsSignedIn(User))
    {
        var userEntity = await UserManager.GetUserAsync(User);
        points = userEntity?.Points ?? 0;
    }
}

@if (SignInManager.IsSignedIn(User))
{
    <div class="masck-account">
        <span class="masck-points">Points: @points</span>

        <a class="masck-account-btn" asp-page="/Profile">
            <span class="masck-account-icon">👤</span>
            MY ACCOUNT <span class="masck-caret">▾</span>
        </a>

        <form class="masck-logout" asp-area="Identity" asp-page="/Account/Logout" method="post">
            <button type="submit" class="masck-link-btn">Logout</button>
        </form>
    </div>
}
else
{
    <div class="masck-account">
        <a class="masck-link-btn" asp-area="Identity" asp-page="/Account/Login">Login</a>
        <a class="masck-link-btn" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </div>
}