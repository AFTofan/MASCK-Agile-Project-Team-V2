@page
@model WebApplication1.Pages.ProfileModel
@{
    ViewData["Title"] = "Profile";
}

<div class="masck-hero mb-4">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center">
        <div>
            <h1 class="fw-bold mb-1">Profile</h1>
            <div class="text-muted">Your account, points, and reward history.</div>
        </div>

        <div class="masck-points-big">
            <div class="text-muted small">Total Points</div>
            <div class="fw-bold" style="font-size:32px; line-height:1;">
                @(Model.CurrentUser?.Points ?? 0)
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card masck-card p-4 h-100">
            <h5 class="fw-bold mb-3">Account</h5>

            <div class="mb-2">
                <div class="text-muted small">Signed in as</div>
                <div class="fw-bold">@User.Identity?.Name</div>
            </div>

            <div class="mb-3">
                <div class="text-muted small">Email</div>
                <div>@(Model.CurrentUser?.Email ?? "-")</div>
            </div>

            <div class="d-grid gap-2">
                <a class="btn btn-masck" asp-area="Identity" asp-page="/Account/Manage/Index">
                    Manage Account
                </a>
                <a class="btn btn-masck-secondary" asp-page="/Qr/Claim">
                    Claim QR (enter code)
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card masck-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">QR Claim History</h5>
                <div class="text-muted">Total claims: <span class="fw-bold">@Model.Claims.Count</span></div>
            </div>

            @if (Model.Claims.Count == 0)
            {
                <div class="text-muted">No QR codes claimed yet. Scan one while logged in to earn points.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table masck-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th style="width:120px;">Points</th>
                                <th style="width:220px;">Claimed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Claims)
                            {
                                <tr>
                                    <td><span class="masck-code">@c.Code</span></td>
                                    <td class="fw-bold">+@c.Points</td>
                                    <td class="text-muted">@c.ClaimedAtUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>