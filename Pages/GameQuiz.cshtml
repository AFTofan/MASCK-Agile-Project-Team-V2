@page
@model PageModel
@{
    ViewData["Title"] = "Game Quiz";
}

<div class="card masck-card p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
        <div>
            <h2 class="fw-bold mb-1">Game Quiz</h2>
            <p class="text-muted mb-0">Answer questions and track your score.</p>
        </div>
        <div class="fw-bold">
            Score: <span id="gq-score">0</span>
        </div>
    </div>

    <hr class="my-4" style="border-color: rgba(255,255,255,.08);" />

    <div id="gq-card" class="p-3 rounded" style="background: rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08);">
        <div class="text-muted">Press “Start” to begin.</div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button id="gq-start" class="btn btn-masck">Start</button>
        <button id="gq-next" class="btn btn-outline-light" disabled>Next</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/game-quiz.js" asp-append-version="true"></script>
}