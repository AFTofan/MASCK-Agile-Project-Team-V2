@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero">
    <h1>Welcome to Luton Town Learning Platform</h1>
    <p>Discover the beautiful quiz with interactive lessons and fun challenges!</p>
</section>

<!-- Announcements Section -->
<section class="announcements-section">
    <div class="announcements-container">
        <div class="announcement-badge">📢 Latest News</div>
        <h2 class="announcements-title">What's New</h2>

        <div class="announcements-list">
            <div class="announcement-card">
                <div class="announcement-icon">⚽</div>
                <div class="announcement-content">
                    <h3>New Lessons Added!</h3>
                    <p>Learn about football basics, stadium history, and famous players with 15 interactive facts per lesson.</p>
                    <span class="announcement-date">February 10, 2026</span>
                </div>
            </div>

            <div class="announcement-card">
                <div class="announcement-icon">🎮</div>
                <div class="announcement-content">
                    <h3>Fun Quizzes Available</h3>
                    <p>Test your knowledge with our challenging quizzes and earn achievements!</p>
                    <span class="announcement-date">February 8, 2026</span>
                </div>
            </div>

            <div class="announcement-card">
                <div class="announcement-icon">🏆</div>
                <div class="announcement-content">
                    <h3>Collect Achievements</h3>
                    <p>Complete lessons and quizzes to unlock special badges and rewards.</p>
                    <span class="announcement-date">February 5, 2026</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action Cards -->
<section class="cta-section">
    <div class="cta-container">
        <h2 class="cta-heading">Ready to Start Learning?</h2>

        <div class="cta-cards">

            <!-- Learning Card -->
            <a asp-page="/LearningTime" class="cta-card cta-card--learning">
                <div class="cta-card-content">
                    <div class="cta-icon">📚</div>
                    <h3 class="cta-title">Let's Learn Together</h3>
                    <p class="cta-description">Explore interactive lessons about football, tactics, history, and more!</p>
                    <span class="cta-button">Start Learning →</span>
                </div>
                <div class="cta-card-bg">
                    <div class="cta-pattern"></div>
                </div>
            </a>

            <!-- Games Card -->
            <a asp-page="/GameQuiz" class="cta-card cta-card--quiz">
                <div class="cta-card-content">
                    <div class="cta-icon">🎮</div>
                    <h3 class="cta-title">Play Fun Games</h3>
                    <p class="cta-description">Quizzes, puzzles, and interactive football games!</p>
                    <span class="cta-button">Play Now →</span>
                </div>
                <div class="cta-card-bg">
                    <div class="cta-pattern"></div>
                </div>
            </a>

            <!-- Achievements Card -->
            <a asp-page="/Profile" class="cta-card cta-card--achievements">
                <div class="cta-card-content">
                    <div class="cta-icon">🏆</div>
                    <h3 class="cta-title">Earn Rewards</h3>
                    <p class="cta-description">Complete challenges to unlock badges and climb the leaderboard!</p>
                    <span class="cta-button">View Achievements →</span>
                </div>
                <div class="cta-card-bg">
                    <div class="cta-pattern"></div>
                </div>
            </a>

        </div>
    </div>
</section>
<!-- Footer Branding (Big "WE'RE ALL LUTON" Image) -->
<section class="footer-branding">
    <div class="footer-branding">
        <div class="footer-branding-container">
            <img src="~/background-image/Luton-Town-Team-Identity-Logo-Design-PNG.png"
                 alt="Luton Town Football Club Logo"
                 class="footer-logo-image">
        </div>
    </div>
</section>

